# Copiar este archivo como .env en el VPS (fuera del repositorio, nunca se sube a GitHub)
# y llenar con valores reales.

# Correo usado por Traefik/Let's Encrypt para avisos de expiracion de certificados
ACME_EMAIL=tu_correo@example.com

# Credenciales de PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=cambia_esta_clave
POSTGRES_DB=appdb

# Imagenes publicadas en GitHub Container Registry por el workflow de CI/CD
BACKEND_IMAGE=ghcr.io/alexisj3489/proyecto-backend
FRONTEND_IMAGE=ghcr.io/alexisj3489/proyecto-frontend
IMAGE_TAG=3.0.0
